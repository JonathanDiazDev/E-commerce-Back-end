{
  "info": {
    "name": "E-Commerce API",
    "description": "REST API for the e-commerce backend. Variables:  baseUrl (default http://localhost:8080),  token (JWT access token).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Public authentication endpoints (no Bearer token required).",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v1/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "register"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"Str0ng!Pass123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "login"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"Str0ng!Pass123\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v1/auth/refresh", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "refresh"] },
            "header": [{ "key": "Cookie", "value": "refresh_token=your_refresh_token_value" }]
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v1/auth/logout", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "logout"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Cookie", "value": "refresh_token=your_refresh_token_value; access_token={{token}}" }
            ]
          }
        },
        {
          "name": "Logout All Devices",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v1/auth/logout-all", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "logout-all"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PATCH",
            "url": { "raw": "{{baseUrl}}/api/v1/auth/change-password", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "change-password"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"Str0ng!Pass123\",\n  \"newPassword\": \"N3w!Str0ngPass456\"\n}"
            }
          }
        },
        {
          "name": "Get Current User (Me)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "me"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Active Sessions",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/auth/sessions", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "sessions"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Products",
      "description": "Product catalog. GET routes are public; POST/PUT/DELETE require ADMIN role.",
      "item": [
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v1/products/create", "host": ["{{baseUrl}}"], "path": ["api", "v1", "products", "create"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Wireless Mouse\",\n  \"description\": \"Ergonomic wireless mouse with USB receiver\",\n  \"price\": 29.99,\n  \"stock\": 150,\n  \"categoryId\": 1\n}"
            }
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/api/v1/products/1", "host": ["{{baseUrl}}"], "path": ["api", "v1", "products", "1"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Wireless Mouse Pro\",\n  \"description\": \"Updated ergonomic wireless mouse\",\n  \"price\": 39.99,\n  \"stock\": 200,\n  \"categoryId\": 1\n}"
            }
          }
        },
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/products", "host": ["{{baseUrl}}"], "path": ["api", "v1", "products"] },
            "header": []
          }
        },
        {
          "name": "Get Product By ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/products/1", "host": ["{{baseUrl}}"], "path": ["api", "v1", "products", "1"] },
            "header": []
          }
        },
        {
          "name": "Get Products By Category",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/category?category=Electronics",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "category"],
              "query": [{ "key": "category", "value": "Electronics" }]
            },
            "header": []
          }
        },
        {
          "name": "Get Products By Name",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/name?name=Mouse",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "name"],
              "query": [{ "key": "name", "value": "Mouse" }]
            },
            "header": []
          }
        },
        {
          "name": "Get Products By Price Range",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/price?min=10&max=100",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "price"],
              "query": [
                { "key": "min", "value": "10" },
                { "key": "max", "value": "100" }
              ]
            },
            "header": []
          }
        },
        {
          "name": "Deactivate Product",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/v1/products/1", "host": ["{{baseUrl}}"], "path": ["api", "v1", "products", "1"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Categories",
      "description": "Category management. GET routes are public; POST/DELETE require ADMIN role.",
      "item": [
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v1/categories/create", "host": ["{{baseUrl}}"], "path": ["api", "v1", "categories", "create"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Electronics\",\n  \"parentCategoryId\": null\n}"
            }
          }
        },
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/categories", "host": ["{{baseUrl}}"], "path": ["api", "v1", "categories"] },
            "header": []
          }
        },
        {
          "name": "Get Category By ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/categories/1", "host": ["{{baseUrl}}"], "path": ["api", "v1", "categories", "1"] },
            "header": []
          }
        },
        {
          "name": "Get Root Categories",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/categories/root-categories", "host": ["{{baseUrl}}"], "path": ["api", "v1", "categories", "root-categories"] },
            "header": []
          }
        },
        {
          "name": "Deactivate Category",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/v1/categories/1", "host": ["{{baseUrl}}"], "path": ["api", "v1", "categories", "1"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Cart",
      "description": "Shopping cart operations. All routes require authentication (USER role).",
      "item": [
        {
          "name": "Add Item to Cart",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v1/carts/item", "host": ["{{baseUrl}}"], "path": ["api", "v1", "carts", "item"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": 1,\n  \"quantity\": 2\n}"
            }
          }
        },
        {
          "name": "Remove Item from Cart",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/v1/carts/item/1", "host": ["{{baseUrl}}"], "path": ["api", "v1", "carts", "item", "1"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update Cart Item Quantity",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/api/v1/carts/item/1", "host": ["{{baseUrl}}"], "path": ["api", "v1", "carts", "item", "1"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 3\n}"
            }
          }
        },
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/carts", "host": ["{{baseUrl}}"], "path": ["api", "v1", "carts"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Orders",
      "description": "Order management. Checkout and listing require USER or ADMIN role.",
      "item": [
        {
          "name": "Checkout",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v1/orders/checkout", "host": ["{{baseUrl}}"], "path": ["api", "v1", "orders", "checkout"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cartId\": 1,\n  \"paymentMethodId\": \"pm_card_visa\"\n}"
            }
          }
        },
        {
          "name": "Get All Orders",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/orders", "host": ["{{baseUrl}}"], "path": ["api", "v1", "orders"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Order By ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/orders/1", "host": ["{{baseUrl}}"], "path": ["api", "v1", "orders", "1"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Payments",
      "description": "Payment processing. Requires USER or ADMIN role.",
      "item": [
        {
          "name": "Process Payment",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v1/payments/process", "host": ["{{baseUrl}}"], "path": ["api", "v1", "payments", "process"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": 1,\n  \"paymentMethodId\": \"pm_card_visa\",\n  \"amount\": 59.98\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Webhooks",
      "description": "Stripe webhook receiver (public, no auth).",
      "item": [
        {
          "name": "Stripe Webhook",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v1/webhooks/stripe", "host": ["{{baseUrl}}"], "path": ["api", "v1", "webhooks", "stripe"] },
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Stripe-Signature", "value": "t=1728000000,v1=stripe_test_signature" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"evt_test_webhook\",\n  \"type\": \"payment_intent.succeeded\",\n  \"data\": {\n    \"object\": {\n      \"id\": \"pi_test_payment_intent\",\n      \"amount\": 5998,\n      \"status\": \"succeeded\"\n    }\n  }\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Refunds",
      "description": "Refund requests. Requires ADMIN role.",
      "item": [
        {
          "name": "Request Refund",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v1/refunds", "host": ["{{baseUrl}}"], "path": ["api", "v1", "refunds"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": 1,\n  \"reason\": \"Defective product received\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Inventory",
      "description": "Stock management. Requires ADMIN role.",
      "item": [
        {
          "name": "Get Stock Details",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/inventories/1", "host": ["{{baseUrl}}"], "path": ["api", "v1", "inventories", "1"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Movement History",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/inventories/product/1/history?page=0&size=10&sortBy=date&direction=desc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "inventories", "product", "1", "history"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "sortBy", "value": "date" },
                { "key": "direction", "value": "desc" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Add Stock",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/v1/inventories/1/add?quantity=50&reason=RESTOCK",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "inventories", "1", "add"],
              "query": [
                { "key": "quantity", "value": "50" },
                { "key": "reason", "value": "RESTOCK" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Deduct Stock",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/v1/inventories/1/deduct?quantity=10&reason=SALE",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "inventories", "1", "deduct"],
              "query": [
                { "key": "quantity", "value": "10" },
                { "key": "reason", "value": "SALE" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update Inventory Status",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/api/v1/inventories/1/status?status=OUT_OF_STOCK",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "inventories", "1", "status"],
              "query": [{ "key": "status", "value": "OUT_OF_STOCK" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Password Reset",
      "description": "Password reset flow (public endpoints).",
      "item": [
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v1/password-reset/forgot-password", "host": ["{{baseUrl}}"], "path": ["api", "v1", "password-reset", "forgot-password"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\"\n}"
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v1/password-reset/reset-password", "host": ["{{baseUrl}}"], "path": ["api", "v1", "password-reset", "reset-password"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"abc123-reset-token-from-email\",\n  \"newPassword\": \"N3w!Str0ngPass789\"\n}"
            }
          }
        }
      ]
    }
  ]
}
